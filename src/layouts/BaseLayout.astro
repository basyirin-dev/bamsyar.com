---
/**
 * src/layouts/BaseLayout.astro
 *
 * Complete base layout with full Open Graph, Twitter Card, Google Scholar
 * citation meta tags, canonical URL, and structured data (JSON-LD).
 *
 * Replaces the Stage 1 skeleton with complete Stage 7 SEO infrastructure.
 */

import '../styles/global.css';
import 'katex/dist/katex.min.css';

interface Props {
  title:        string;
  description?: string;
  /** Pass true on article pages to activate Scholar meta and article OG type */
  article?:     boolean;
  publishDate?: Date;
  arxivId?:     string;
  /** Pass an array of author strings for multi-author articles */
  authors?:     string[];
  /** Absolute URL to a 1200×630 OG image */
  ogImage?:     string;
}

const SITE_NAME    = 'Basyirin Amsyar';
const SITE_URL     = Astro.site ?? 'https://bamsyar.pages.dev';
const DEFAULT_DESC = 'Research notes on schema coherence, AI agent training, and physics-informed machine learning.';
const DEFAULT_OG   = new URL('/og-default.png', SITE_URL).toString();
const AUTHOR_NAME  = 'Basyirin Amsyar';

const {
  title,
  description = DEFAULT_DESC,
  article     = false,
  publishDate,
  arxivId,
  authors     = [AUTHOR_NAME],
  ogImage     = DEFAULT_OG,
} = Astro.props;

// Canonical URL — always absolute, trailing-slash-normalised to match
// Astro's default URL structure (no trailing slash on article pages).
const canonicalURL = new URL(Astro.url.pathname, SITE_URL);
canonicalURL.search = '';   // strip query params from canonical

// Full page title
const fullTitle = title === SITE_NAME ? title : `${title} — ${SITE_NAME}`;

// ISO date string for meta tags
const pubDateISO   = publishDate?.toISOString() ?? '';
const pubYear      = publishDate?.getFullYear()?.toString() ?? '';

// JSON-LD structured data
const jsonLdArticle = article ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type':    'ScholarlyArticle',
  'headline': title,
  'description': description,
  'author': authors.map(name => ({ '@type': 'Person', 'name': name })),
  'datePublished': pubDateISO,
  'url': canonicalURL.toString(),
  ...(arxivId && { 'sameAs': `https://arxiv.org/abs/${arxivId}` }),
  'publisher': {
    '@type': 'Person',
    'name':  AUTHOR_NAME,
    'url':   SITE_URL.toString(),
  },
  'mainEntityOfPage': {
    '@type': '@id',
    '@id':   canonicalURL.toString(),
  },
}) : null;

const jsonLdPerson = !article ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type':    'Person',
  'name':     AUTHOR_NAME,
  'url':      SITE_URL.toString(),
  'sameAs': [
    'https://github.com/bamsyar',  // update to real username
  ],
}) : null;
---

<!doctype html>
<html lang="en">
<head>

  <!-- ── Core ────────────────────────────────────────────────────── -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0f0f0f" />
  <meta name="color-scheme" content="dark" />

  <!-- ── Title and description ───────────────────────────────────── -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />

  <!-- ── Canonical URL ───────────────────────────────────────────── -->
  <link rel="canonical" href={canonicalURL} />

  <!-- ── Sitemap reference ───────────────────────────────────────── -->
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- ── Open Graph ──────────────────────────────────────────────── -->
  <!--
    og:type is "article" on article pages, "website" on all others.
    This is what social platforms use to decide how to render the card.
    article:published_time and article:author are ignored on website pages.
  -->
  <meta property="og:site_name"   content={SITE_NAME} />
  <meta property="og:locale"      content="en_US" />
  <meta property="og:type"        content={article ? 'article' : 'website'} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt"   content={`Open Graph image for: ${title}`} />

  {article && publishDate && (
    <meta property="article:published_time" content={pubDateISO} />
  )}
  {article && authors.map(a => (
    <meta property="article:author" content={a} />
  ))}

  <!-- ── Twitter / X Card ────────────────────────────────────────── -->
  <!--
    summary_large_image renders a full-width card preview.
    This is the correct choice for research articles — it gives the
    OG image prominent real estate in the card rather than a thumbnail.
  -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />
  <meta name="twitter:image:alt"   content={`Open Graph image for: ${title}`} />
  <!--
    twitter:site and twitter:creator require a Twitter/X handle.
    Uncomment and fill when you have one.
  -->
  <!-- <meta name="twitter:site"    content="@yourtwitterhandle" /> -->
  <!-- <meta name="twitter:creator" content="@yourtwitterhandle" /> -->

  <!-- ── Google Scholar citation meta ────────────────────────────── -->
  <!--
    These tags are parsed by Google Scholar's crawler (Googlebot-Scholar)
    and make the article appear as a citable document in Scholar search
    results. They are ONLY emitted on article pages where publishDate is
    set. Omitting them on non-article pages prevents Scholar from indexing
    the homepage or papers list as citable documents.

    Required tags for Scholar indexing:
      citation_title            — article title
      citation_author           — one tag per author, "Last, First" format
      citation_publication_date — YYYY/MM/DD format
      citation_fulltext_html_url — canonical URL of the article

    Optional but high-value tags:
      citation_arxiv_id         — enables arXiv linking in Scholar
      citation_language         — BCP 47 language code
      citation_keywords         — comma-separated topic keywords

    Reference: https://scholar.google.com/intl/en/scholar/inclusion.html
  -->
  {article && publishDate && (
    <>
      <meta name="citation_title"            content={title} />
      {authors.map(a => (
        <meta name="citation_author" content={a} />
      ))}
      <meta
        name="citation_publication_date"
        content={`${publishDate.getFullYear()}/${String(publishDate.getMonth() + 1).padStart(2, '0')}/${String(publishDate.getDate()).padStart(2, '0')}`}
      />
      <meta name="citation_fulltext_html_url" content={canonicalURL.toString()} />
      <meta name="citation_language"          content="en" />
      {arxivId && (
        <>
          <meta name="citation_arxiv_id" content={arxivId} />
          <meta name="citation_online_date" content={pubYear} />
        </>
      )}
    </>
  )}

  <!-- ── Structured Data (JSON-LD) ───────────────────────────────── -->
  <!--
    JSON-LD is the preferred structured data format for Google Search.
    ScholarlyArticle schema improves Rich Results eligibility for
    research content. Person schema on the homepage signals authorship
    to crawlers.

    Note: JSON-LD is evaluated independently of OG/Twitter meta tags.
    Both are required for full coverage across Google, LinkedIn, Twitter,
    and Slack unfurls.
  -->
  {jsonLdArticle && (
    <script type="application/ld+json" set:html={jsonLdArticle} />
  )}
  {jsonLdPerson && (
    <script type="application/ld+json" set:html={jsonLdPerson} />
  )}

  <!-- ── Fonts (Local @fontsource/inter) ────────────────────────── -->
  <!--
    Inter font loaded locally via @fontsource/inter package.
    This eliminates duplicate font loading and ensures consistency
    between web fonts and Open Graph image generation.
  -->

  <!-- ── Favicon ─────────────────────────────────────────────────── -->
  <!--
    Minimal favicon set. Place these files in public/:
      public/favicon.ico          — legacy browsers (16×16, 32×32 ICO)
      public/favicon.svg          — modern browsers (vector, dark-mode aware)
      public/apple-touch-icon.png — iOS home screen (180×180 PNG)

    The SVG favicon can include a dark/light mode switch via
    @media (prefers-color-scheme: dark) { ... } in its embedded CSS.
  -->
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

</head>
<body>

  <!-- ── Skip-to-content (accessibility) ─────────────────────────── -->
  <a
    href="#main-content"
    style="position: absolute; left: -9999px; top: 1rem; z-index: 9999; padding: 0.5rem 1rem; background: #a78bfa; color: #0f0f0f; font-weight: 600; border-radius: 0.25rem; text-decoration: none;"
    onfocus="this.style.left='1rem'"
    onblur="this.style.left='-9999px'"
  >
    Skip to content
  </a>

  <!-- ── Header / Navigation ──────────────────────────────────────── -->
  <header class="sticky top-0 z-40 bg-black/95 backdrop-blur-lg border-b border-gray-800">
    <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-8" role="navigation" aria-label="Main navigation">
      <a href="/" class="text-gray-100 font-semibold text-sm tracking-wide">
        Basyirin Amsyar
      </a>
      <div class="flex gap-6 ml-auto">
        {[
          { href: '/articles', label: 'Articles' },
          { href: '/papers',   label: 'Papers'   },
          { href: '/projects', label: 'Projects' },
          { href: '/about',    label: 'About'    },
        ].map(({ href, label }) => {
          const isActive = Astro.url.pathname.startsWith(href);
          return (
            <a
              href={href}
              class={`text-sm font-medium transition-colors duration-200 ${
                isActive
                  ? 'text-purple-400 hover:text-purple-300'
                  : 'text-gray-500 hover:text-gray-300'
              }`}
              aria-current={isActive ? "page" : undefined}
            >
              {label}
            </a>
          );
        })}
      </div>
    </nav>
  </header>

  <!-- ── Main content ─────────────────────────────────────────────── -->
  <main id="main-content" class="max-w-5xl mx-auto px-6 py-12 w-full flex-1">
    <slot />
  </main>

  <!-- ── Footer ───────────────────────────────────────────────────── -->
  <footer class="border-t border-gray-800 py-8 px-6">
    <div class="max-w-5xl mx-auto flex flex-wrap items-center justify-between gap-3 text-xs text-gray-500">
      <span>© {new Date().getFullYear()} Basyirin Amsyar</span>
      <div class="flex gap-5">
        <a href="https://github.com/bamsyar" class="text-gray-500 hover:text-gray-300 transition-colors">
          GitHub
        </a>
        <a href="https://arxiv.org/search/?searchtype=author&query=Amsyar" class="text-gray-500 hover:text-gray-300 transition-colors">
          arXiv
        </a>
        <a href="mailto:bamsyar@example.com" class="text-gray-500 hover:text-gray-300 transition-colors">
          Contact
        </a>
      </div>
    </div>
  </footer>

</body>
</html>
