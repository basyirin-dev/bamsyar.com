---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'articles'>;
}

const { entry } = Astro.props;
const { title, description, publishDate, updatedDate, tags, arxivId, readingTime } = entry.data;

const pubDateFormatted = publishDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const pubDateISO = publishDate.toISOString();

const updDateFormatted = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const updDateISO = updatedDate?.toISOString();

const arxivUrl = arxivId ? `https://arxiv.org/abs/${arxivId}` : null;

const bibtexString = arxivId
  ? `@misc{${entry.id.replace(/[^a-zA-Z0-9]/g, '_')},
  author        = {Basyirin Amsyar},
  title         = {${title}},
  year          = {${publishDate.getFullYear()}},
  eprint        = {${arxivId}},
  archivePrefix = {arXiv},
  primaryClass  = {cs.AI},
  url           = {https://arxiv.org/abs/${arxivId}}
}`
  : `@misc{${entry.id.replace(/[^a-zA-Z0-9]/g, '_')},
  author       = {Basyirin Amsyar},
  title        = {${title}},
  year         = {${publishDate.getFullYear()}},
  howpublished = {\\url{https://bamsyar.pages.dev/articles/${entry.id}}},
  note         = {Online article}
}`;
---

<BaseLayout
  {title}
  {description}
  article={true}
  publishDate={pubDateISO}
  {arxivId}
>
  <article>

    <!-- ARTICLE HEADER -->
    <header class="mb-10 pb-8 border-b border-[#262626]">

      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map(tag => (
          <a href={`/articles?tag=${encodeURIComponent(tag)}`} class="text-[11px] uppercase tracking-wider text-[#a78bfa] hover:text-white bg-violet-950/30 border border-violet-800/40 px-2 py-0.5 rounded transition-colors duration-150">
            {tag}
          </a>
        ))}
      </div>

      <h1 class="text-2xl font-semibold text-white leading-snug tracking-tight mb-4">
        {title}
      </h1>

      <p class="text-[#a3a3a3] text-base leading-relaxed mb-5">
        {description}
      </p>

      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-[#525252]">

        <time datetime={pubDateISO} class="text-[#737373]">
          {pubDateFormatted}
        </time>

        {readingTime && (
          <span class="text-[#525252]">{readingTime} min read</span>
        )}

        {updatedDate && (
          <span class="text-[#525252]">
            Updated <time datetime={updDateISO}>{updDateFormatted}</time>
          </span>
        )}

        {arxivUrl && (
          <a href={arxivUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-wider text-[#a78bfa] hover:text-white border border-violet-800/50 bg-violet-950/30 px-2.5 py-1 rounded transition-colors duration-150">
            arXiv:{arxivId}
          </a>
        )}

      </div>
    </header>

    <!-- ARTICLE BODY -->
    <div class="prose prose-invert max-w-none">
      <slot />
    </div>

    <!-- POST-BODY FOOTER -->
    <footer class="mt-14 pt-8 border-t border-[#262626] space-y-8">

      <div>
        <h2 class="text-xs uppercase tracking-widest text-[#525252] mb-3 font-medium">
          Citation
        </h2>
        <details class="group">
          <summary class="cursor-pointer text-sm text-[#a3a3a3] hover:text-white transition-colors duration-150 list-none flex items-center gap-2">
            <span class="text-[#525252] group-open:rotate-90 transition-transform duration-150 inline-block select-none">▶</span>
            Show BibTeX
          </summary>
          <pre class="mt-3 bg-[#161616] border border-[#262626] rounded-lg px-4 py-3 text-[0.8rem] text-[#a3a3a3] font-mono overflow-x-auto leading-relaxed whitespace-pre-wrap break-words">{bibtexString}</pre>
        </details>
      </div>

    </footer>

  </article>
</BaseLayout>
