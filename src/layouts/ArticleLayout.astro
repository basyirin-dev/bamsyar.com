---
/**
 * src/layouts/ArticleLayout.astro
 *
 * Complete article layout: header meta, prose body, BibTeX block,
 * Giscus comment section. Replaces the Stage 3 skeleton.
 */

import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Giscus from '../components/Giscus.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { giscus } from '../config/site';
import 'katex/dist/katex.min.css';

interface Props {
  entry: CollectionEntry<'articles'>;
  readingTime?: number;
}

const { entry, readingTime } = Astro.props;
const { title, description, publishDate, updatedDate, tags, arxivId } = entry.data;


// Canonical URL for this article
const canonicalURL = new URL(`/articles/${entry.id}`, Astro.site);

// OG image: use entry.data.ogImage if provided, otherwise use generated path
const ogImage = entry.data.ogImage || new URL(`/og/${entry.id}.png`, Astro.site).toString();

// Formatted dates
const pubDateISO      = publishDate.toISOString();
const pubDateDisplay  = publishDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const updDateDisplay  = updatedDate
  ? updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

// BibTeX generation
const pubYear = publishDate.getFullYear();
const citeKey = `amsyar${pubYear}`;  // e.g. amsyar2026

const bibtex = arxivId
  ? `@misc{${citeKey},
  title   = {${title}},
  author  = {Amsyar, Basyirin},
  year    = {${pubYear}},
  eprint  = {${arxivId}},
  archivePrefix = {arXiv},
  primaryClass  = {cs.AI},
  url     = {https://arxiv.org/abs/${arxivId}}
}`
  : `@misc{${citeKey},
  title   = {${title}},
  author  = {Amsyar, Basyirin},
  year    = {${pubYear}},
  url     = {${canonicalURL}},
  note    = {bamsyar.com}
}`;
---

<BaseLayout
  title={title}
  description={description}
  article={true}
  publishDate={publishDate}
  arxivId={arxivId}
  ogImage={ogImage}
>
  <!-- IBM Plex Mono font loading for article pages only -->
  <link rel="preload" href="/fonts/ibm-plex-mono-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href="/fonts/ibm-plex-mono-latin-500-normal.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

  <style>
    @font-face {
      font-family: 'IBM Plex Mono';
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url('/fonts/ibm-plex-mono-latin-400-normal.woff2') format('woff2');
    }

    @font-face {
      font-family: 'IBM Plex Mono';
      font-style: normal;
      font-weight: 500;
      font-display: swap;
      src: url('/fonts/ibm-plex-mono-latin-500-normal.woff2') format('woff2');
    }
  </style>

  <div class="max-w-6xl mx-auto px-4 lg:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <article class="lg:col-span-3">

    <!-- ── Article header ──────────────────────────────────────────── -->
    <header style="margin-bottom: 2.5rem;">

      <!-- Tag pills -->
      <div style="display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1rem;">
        {tags.map((tag: string) => (
          <a
            href={`/articles?tag=${encodeURIComponent(tag)}`}
            style="display: inline-block; padding: 0.15rem 0.6rem; border-radius: 9999px; border: 1px solid #404040; color: #a3a3a3; font-size: 0.72rem; text-decoration: none; letter-spacing: 0.04em; transition: border-color 0.15s, color 0.15s;"
          >
            {tag}
          </a>
        ))}
      </div>

      <!-- Title -->
      <h1 style="font-size: clamp(1.5rem, 4vw, 2.1rem); font-weight: 700; line-height: 1.2; color: #f5f5f5; margin-bottom: 0.875rem;">
        {title}
      </h1>

      <!-- Description -->
      <p style="font-size: 1.05rem; color: #a3a3a3; line-height: 1.6; margin-bottom: 1.25rem;">
        {description}
      </p>

      <!-- Meta row: date · reading time · updated · arXiv -->
      <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem 1.25rem; font-size: 0.8rem; color: #737373;">
        <time datetime={pubDateISO}>{pubDateDisplay}</time>

        {readingTime && (
          <span>{readingTime} min read</span>
        )}

        {updDateDisplay && (
          <span>Updated {updDateDisplay}</span>
        )}

        {arxivId && (
          <a
            href={`https://arxiv.org/abs/${arxivId}`}
            target="_blank"
            rel="noopener noreferrer"
            style="display: inline-flex; align-items: center; gap: 0.3rem; color: #a78bfa; text-decoration: none; border: 1px solid #a78bfa44; border-radius: 0.3rem; padding: 0.1rem 0.5rem; font-size: 0.72rem; letter-spacing: 0.04em;"
          >
            arXiv:{arxivId}
          </a>
        )}
      </div>

    </header>

    <!-- ── Article body ─────────────────────────────────────────────── -->
    <div class="prose prose-invert max-w-none">
      <slot />
    </div>

    <!-- ── Article footer ──────────────────────────────────────────── -->
    <footer style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #262626;">

      <!-- BibTeX citation block -->
      <details style="margin-bottom: 2rem;">
        <summary style="cursor: pointer; color: #737373; font-size: 0.8rem; letter-spacing: 0.04em; text-transform: uppercase; font-weight: 600; user-select: none;">
          Cite this article
        </summary>
        <div style="margin-top: 0.875rem;">
          <pre style="background: #161616; border: 1px solid #262626; border-radius: 0.5rem; padding: 1rem 1.25rem; font-size: 0.78rem; font-family: 'IBM Plex Mono', monospace; color: #e5e5e5; overflow-x: auto; line-height: 1.65; white-space: pre;">
{bibtex}
          </pre>
          <p style="margin-top: 0.5rem; color: #525252; font-size: 0.72rem;">
            {arxivId
              ? 'arXiv preprint. Update citation once formally published.'
              : 'No arXiv ID yet. Will be updated on preprint submission.'}
          </p>
        </div>
      </details>

    </footer>

  </article>

  <!-- ── Table of Contents ───────────────────────────────────────── -->
  <aside class="lg:col-span-1">
    <TableOfContents entry={entry} />
  </aside>

</div>
  </div>

  <!-- ── Giscus comments ─────────────────────────────────────────── -->
  <!--
    Placed outside <article> so the discussion section is semantically
    separate from the article content. Screen readers and document
    outlines benefit from this separation.
  -->
  <Giscus
    repo={giscus.repo}
    repoId={giscus.repoId}
    category={giscus.category}
    categoryId={giscus.categoryId}
  />

</BaseLayout>
