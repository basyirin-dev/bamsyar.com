---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Basyirin Amsyar — Research"
  description="Research notes on AI systems, schema coherence, and physics-informed machine learning. Home of the H-Bar Model."
>
  <!-- Identity block -->
  <div class="mb-12">
    <h1 class="text-2xl font-semibold text-white mb-2 tracking-tight">
      Basyirin Amsyar
    </h1>
    <p class="text-[#a3a3a3] text-base leading-relaxed max-w-xl">
      Research notes on AI systems, schema coherence, and physics-informed machine learning.
      Interested in the formal structure of how knowledge develops in both human and artificial agents.
    </p>
  </div>

  <!-- Writing section -->
  <section class="mb-10">
    <h2 class="text-xs uppercase tracking-widest text-[#525252] mb-5 font-medium">
      Writing
    </h2>
    <p class="text-[#a3a3a3] text-sm">Articles coming soon.</p>
    <!--
      In Stage 5, replace this with a dynamic article list built from
      the Content Collections query. Pattern:

      const articles = await getCollection('articles', ({ data }) => !data.draft);
      articles.sort((a, b) => b.data.publishDate - a.data.publishDate);

      Then map over articles to render a list of titles + dates.
    -->
  </section>

  <!-- Papers section -->
  <section>
    <h2 class="text-xs uppercase tracking-widest text-[#525252] mb-5 font-medium">
      Papers
    </h2>
    <p class="text-[#a3a3a3] text-sm">In preparation.</p>
  </section>
</BaseLayout>
