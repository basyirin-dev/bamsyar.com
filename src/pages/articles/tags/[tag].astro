---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getArticlesByTag, getAllArticleTags } from '../../../lib/content';

export async function getStaticPaths() {
  const allTags = await getAllArticleTags();
  return allTags.map(tag => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;
if (!tag) {
  throw new Error('Tag parameter is required');
}
const articles = await getArticlesByTag(tag);
const allTags = await getAllArticleTags();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric',
  });
}

// Set dynamic title and description for SEO
const pageTitle = `${tag} — Articles — Basyirin Amsyar`;
const pageDescription = `Articles tagged with "${tag}". ${articles.length} article${articles.length !== 1 ? 's' : ''} on AI systems, schema coherence, and physics-informed machine learning.`;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
>

  <div class="mb-8">
    <div class="flex items-center gap-4 mb-4">
      <a href="/articles" class="text-[#a78bfa] hover:text-white transition-colors duration-150 text-sm font-medium">
        ← All articles
      </a>
    </div>
    <h1 class="text-xl font-semibold text-white mb-2">Articles tagged: {tag}</h1>
    <p class="text-[#737373] text-sm">
      {articles.length} article{articles.length !== 1 ? 's' : ''} · {pageDescription}
    </p>
  </div>

  {allTags.length > 0 && (
    <div class="mb-8 flex flex-wrap gap-2">
      {allTags.map(t => (
        <a
          href={`/articles/tags/${t}`}
          class={`tag-btn text-[11px] uppercase tracking-wider px-2.5 py-1 rounded border transition-colors duration-150 ${
            t === tag
              ? 'border-[#a78bfa] text-[#a78bfa] bg-violet-950/30'
              : 'border-[#262626] text-[#525252] hover:text-[#a3a3a3] hover:border-[#404040]'
          }`}
        >
          {t}
        </a>
      ))}
    </div>
  )}

  <div class="space-y-0" id="article-list">
    {articles.map(article => (
      <article class="article-item py-5 border-b border-[#1a1a1a] last:border-b-0" data-tags={JSON.stringify(article.data.tags)}>
        <a href={`/articles/${article.id}`} class="group block">

          <div class="flex flex-wrap gap-1.5 mb-2">
            {article.data.tags.slice(0, 4).map(t => (
              <span class={`text-[10px] uppercase tracking-wider ${
                t === tag
                  ? 'text-[#a78bfa]'
                  : 'text-[#525252]'
              }`}>
                {t}
              </span>
            ))}
          </div>

          <h2 class="text-base font-medium text-[#e5e5e5] leading-snug mb-1.5 group-hover:text-white transition-colors duration-150">
            {article.data.title}
          </h2>

          <p class="text-sm text-[#737373] leading-relaxed mb-3">
            {article.data.description}
          </p>

          <div class="flex items-center gap-4 text-xs text-[#525252]">
            <time datetime={article.data.publishDate.toISOString()}>
              {formatDate(article.data.publishDate)}
            </time>
            {article.data.readingTime && (
              <span>{article.data.readingTime} min read</span>
            )}
            {article.data.arxivId && (
              <span class="text-[#737373]">arXiv</span>
            )}
            {article.data.updatedDate && (
              <span>Updated {formatDate(article.data.updatedDate)}</span>
            )}
          </div>

        </a>
      </article>
    ))}
  </div>

  {articles.length === 0 && (
    <div class="text-center py-12">
      <p class="text-[#525252] text-sm mb-4">
        No articles found with the tag "{tag}".
      </p>
      <a href="/articles" class="text-[#a78bfa] hover:text-white transition-colors duration-150 text-sm font-medium">
        Browse all articles
      </a>
    </div>
  )}

</BaseLayout>
