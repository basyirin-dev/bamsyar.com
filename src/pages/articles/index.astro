---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedArticles, getAllArticleTags } from '../../lib/content';

const articles = await getPublishedArticles();
const allTags = await getAllArticleTags();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric',
  });
}
---

<BaseLayout
  title="Articles — Basyirin Amsyar"
  description="Long-form writing on AI systems, schema coherence, and physics-informed machine learning."
>

  <div class="mb-8">
    <h1 class="text-xl font-semibold text-white mb-2">Articles</h1>
    <p class="text-[#737373] text-sm">
      {articles.length} article{articles.length !== 1 ? 's' : ''} · formal writing on AI training, schema coherence, and physics-informed ML
    </p>
  </div>

  {allTags.length > 0 && (
    <div class="mb-8 flex flex-wrap gap-2">
      {allTags.map(t => (
        <a
          href={`/articles/tags/${t}`}
          class="tag-btn text-[11px] uppercase tracking-wider px-2.5 py-1 rounded border transition-colors duration-150 border-[#262626] text-[#525252] hover:text-[#a3a3a3] hover:border-[#404040]"
        >
          {t}
        </a>
      ))}
    </div>
  )}

  <div class="space-y-0" id="article-list">
    {articles.map(article => (
      <article class="article-item py-5 border-b border-[#1a1a1a] last:border-b-0" data-tags={JSON.stringify(article.data.tags)}>
        <a href={`/articles/${article.id}`} class="group block">

          <div class="flex flex-wrap gap-1.5 mb-2">
            {article.data.tags.slice(0, 4).map(tag => (
              <span class="text-[10px] uppercase tracking-wider text-[#a78bfa]">{tag}</span>
            ))}
          </div>

          <h2 class="text-base font-medium text-[#e5e5e5] leading-snug mb-1.5 group-hover:text-white transition-colors duration-150">
            {article.data.title}
          </h2>

          <p class="text-sm text-[#737373] leading-relaxed mb-3">
            {article.data.description}
          </p>

          <div class="flex items-center gap-4 text-xs text-[#525252]">
            <time datetime={article.data.publishDate.toISOString()}>
              {formatDate(article.data.publishDate)}
            </time>
            {article.data.readingTime && (
              <span>{article.data.readingTime} min read</span>
            )}
            {article.data.arxivId && (
              <span class="text-[#737373]">arXiv</span>
            )}
            {article.data.updatedDate && (
              <span>Updated {formatDate(article.data.updatedDate)}</span>
            )}
          </div>

        </a>
      </article>
    ))}
  </div>

  {articles.length === 0 && (
    <p class="text-[#525252] text-sm py-8 text-center">
      No articles published yet. Check back soon.
    </p>
  )}

</BaseLayout>
