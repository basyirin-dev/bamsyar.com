---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import { getAllProjects } from '../../lib/content';

const projects = await getAllProjects();
---

<BaseLayout
  title="Projects — Basyirin Amsyar"
  description="Active research projects: the H-Bar Model of Knowledge Development and Physics-Informed Residual Learning."
>

  <div class="mb-10">
    <h1 class="text-xl font-semibold text-white mb-2">Projects</h1>
    <p class="text-[#737373] text-sm">Active and recent research work.</p>
  </div>

  {projects.map(project => (
    <article class="mb-10 pb-10 border-b border-[#262626] last:border-b-0 last:pb-0">
      <div class="flex items-start justify-between gap-4 mb-3">
        <h2 class="text-base font-semibold text-white leading-snug">
          {project.data.title}
        </h2>
        <StatusBadge status={project.data.status} size="md" />
      </div>

      <p class="text-sm text-[#a3a3a3] leading-relaxed mb-4 max-w-prose">
        {project.data.description}
      </p>

      <div class="text-sm text-[#737373] leading-relaxed mb-5 max-w-prose markdown-content">
        {project.data.details}
      </div>

      <div class="flex flex-wrap gap-4 text-sm">
        {project.data.relatedPapers?.map(paperId => (
          <a href={`/papers#${paperId}`} class="text-[#a78bfa] hover:text-white transition-colors duration-150">
            View paper entry →
          </a>
        ))}
        {project.data.url && (
          <a href={project.data.url} target="_blank" rel="noopener noreferrer" class="text-[#a78bfa] hover:text-white transition-colors duration-150">
            Project website ↗
          </a>
        )}
      </div>

      <div class="flex flex-wrap gap-1.5 mt-3">
        {project.data.tags.map((tag: string) => (
          <span class="text-[10px] uppercase tracking-wider text-[#525252]">{tag}</span>
        ))}
      </div>
    </article>
  ))}

  {projects.length === 0 && (
    <p class="text-[#525252] text-sm py-8 text-center">
      No projects listed yet.
    </p>
  )}

</BaseLayout>
