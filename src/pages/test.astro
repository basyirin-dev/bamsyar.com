---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Typography Test">
  <div class="prose">
    <h1>Heading 1</h1>
    <h2>Heading 2</h2>
    <h3>Heading 3</h3>
    <p>Body text with <a href="#">a link</a>, <strong>bold</strong>, <em>italic</em>,
    and <code>inline code</code>.</p>
    <blockquote>A blockquote for theorem statements or key claims.</blockquote>
    <pre><code>A code block showing preformatted text.</code></pre>
    <table>
      <thead><tr><th>Variable</th><th>Meaning</th></tr></thead>
      <tbody>
        <tr><td>sigma</td><td>Schema coherence</td></tr>
        <tr><td>delta</td><td>Parametric depth</td></tr>
      </tbody>
    </table>
  </div>
</BaseLayout>
