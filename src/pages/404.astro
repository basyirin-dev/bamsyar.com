---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found" description="This page does not exist.">
  <div class="py-20 text-center">
    <p class="text-5xl font-bold text-[#262626] mb-4">404</p>
    <h1 class="text-lg font-medium text-white mb-3">Page not found</h1>
    <p class="text-[#737373] text-sm mb-8">
      The page you're looking for doesn't exist or has moved.
    </p>
    <a
      href="/"
      class="text-sm text-[#a78bfa] hover:text-white transition-colors duration-150"
    >
      ← Return home
    </a>
  </div>
</BaseLayout>
